#!/usr/bin/env bash
set -euo pipefail

root="${FAKE_RCLONE_ROOT:?FAKE_RCLONE_ROOT is required}"
mode="${FAKE_RCLONE_MODE:-skip}"

log_call() {
  printf '%s\n' "$*" >> "$root/rclone.calls"
}

log_call "$*"

if [[ "${1:-}" == "--config" ]]; then
  shift 2
  case "${1:-}" in
    config)
      case "${2:-}" in
        create)
          if [[ "$mode" == "config_create_fail" ]]; then
            exit 1
          fi
          printf '%s\n' "$*" >> "$root/rclone.config-writes"
          exit 0
          ;;
      esac
      ;;
    lsd)
      if [[ "$mode" == "config_probe_fail" ]]; then
        exit 1
      fi
      exit 0
      ;;
  esac
fi

case "${1:-}" in
  config)
    case "${2:-}" in
      create|update)
        if [[ "$mode" == "config_update_fail" && "${2:-}" == "update" ]]; then
          printf '%s\n' "$*" >> "$root/rclone.config-writes"
          exit 1
        fi
        printf '%s\n' "$*" >> "$root/rclone.config-writes"
        exit 0
        ;;
      delete)
        printf '%s\n' "$*" >> "$root/rclone.config-writes"
        exit 0
        ;;
    esac
    exit 0
    ;;
  listremotes)
    if [[ "$mode" == "remote_missing" ]]; then
      exit 0
    fi
    echo "fake:"
    exit 0
    ;;
  lsd)
    if [[ "$mode" == "remote_fail" ]]; then
      exit 1
    fi
    exit 0
    ;;
  lsf)
    args=" $* "
    if [[ "$mode" == "config_path_fail" ]]; then
      exit 1
    fi
    if [[ "$args" == *" -R "* ]]; then
      case "$mode" in
        skip) printf '%s\n' "same.bin" ;;
        stop) printf '%s\n' "slow.bin" ;;
        *) printf '%s\n' "file.bin" ;;
      esac
      exit 0
    fi

    if [[ "$args" != *" --files-only "* ]]; then
      exit 0
    fi

    if [[ "$mode" == "skip" ]]; then
      exit 0
    fi
    exit 1
    ;;
  size)
    printf '%s\n' '{"bytes":11}'
    exit 0
    ;;
  lsjson)
    printf '%s\n' '{"Size":11}'
    exit 0
    ;;
  copyto)
    printf '%s\n' "$$" >> "$root/copyto.pids"
    : > "$root/copyto.started"
    exec sleep 300
    ;;
  *)
    exit 0
    ;;
esac
